{
  "version": "1.0.0",
  "_description": [
    "서드파티 플러그인 자동업데이트 카탈로그 (전 서버 공통 원본).",
    "지원 프레임워크는 Metamod:Source 와 SwiftlyS2 다. CounterStrikeSharp 는 2026-07-12 에 걷어냈다.",
    "",
    "deploy.sh 가 이 카탈로그를 각 서버 볼륨에 이미 설치된 플러그인만 남기고 걸러서",
    "<volume>/egg/configs/plugins.json 으로 내려보낸다. 여기 없는 디렉터리는 절대 건드리지 않는다.",
    "",
    "필드:",
    "  name      : 버전 기록 키.",
    "  detect    : 설치 여부를 판정할 경로 (game/csgo 기준). 필수.",
    "  repo      : GitHub owner/repo. releases/latest 를 조회한다.",
    "  asset     : 릴리스 에셋 이름에 대한 정규식 (jq test()).",
    "  framework : metamod | swiftly. 해당 프레임워크가 꺼진 서버에서는 설치하지 않는다.",
    "  enabled   : false 면 건너뛴다.",
    "  map       : 릴리스 아카이브 내부 경로(from) → game/csgo 기준 목적지(to).",
    "              preserve=true 면 없는 파일만 채우고 기존 파일은 덮어쓰지 않는다 (설정·사용자 데이터).",
    "",
    "map 은 실제 아카이브를 열어 확인한 값이다. 릴리스 구조가 바뀌면 업데이터가 'zip에 X가 없음'으로",
    "중단하고 아무것도 건드리지 않는다. 그때 이 파일을 고칠 것.",
    "",
    "Metamod:Source 본체와 SwiftlyS2 본체는 egg 가 INSTALL_METAMOD/INSTALL_SWIFTLY 로",
    "이미 매 부팅 갱신하므로 여기 넣지 않는다.",
    "",
    "제외된 것과 그 이유는 context-notes.md 참조.",
    "  cs2bhop      우리 것 (cs2kr-plugins/cs2bhop-metamod)",
    "  CS2KR-Core   우리 것 (CS2KR/CS2KR-Core)"
  ],
  "plugins": [
    {
      "name": "CS2-CustomIO",
      "detect": "addons/swiftlys2/plugins/cs2-CustomIO",
      "repo": "himenekocn/CS2-CustomIO-For-SW2",
      "asset": "^cs2-CustomIO\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": ".",
          "to": "addons/swiftlys2/plugins/cs2-CustomIO"
        }
      ],
      "framework": "swiftly",
      "env": "PLUGIN_CS2_CUSTOMIO"
    },
    {
      "name": "cs2bhop-metamod",
      "detect": "addons/cs2bhop",
      "repo": "CS2KR/cs2bhop-metamod",
      "asset": "^cs2bhop-linux-.*-upgrade\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": "addons",
          "to": "addons"
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_CS2BHOP"
    },
    {
      "name": "cs2kz",
      "detect": "addons/cs2kz",
      "repo": "KZGlobalTeam/cs2kz-metamod",
      "asset": "^cs2kz-linux-master-upgrade\\.tar\\.gz$",
      "enabled": true,
      "map": [
        {
          "from": "addons/cs2kz",
          "to": "addons/cs2kz"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        },
        {
          "from": "cfg",
          "to": "cfg",
          "preserve": true
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_CS2KZ"
    },
    {
      "name": "cs2surf",
      "detect": "addons/cs2surf",
      "repo": "rcnoob/cs2surf-metamod",
      "asset": "^cs2surf-linux-master-upgrade\\.tar\\.gz$",
      "enabled": true,
      "map": [
        {
          "from": "addons/cs2surf",
          "to": "addons/cs2surf"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        },
        {
          "from": "cfg",
          "to": "cfg",
          "preserve": true
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_CS2SURF"
    },
    {
      "name": "sql_mm",
      "detect": "addons/sql_mm",
      "repo": "zer0k-z/sql_mm",
      "asset": "^package-linux\\.tar\\.gz$",
      "enabled": true,
      "map": [
        {
          "from": "addons/sql_mm",
          "to": "addons/sql_mm"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_SQL_MM"
    },
    {
      "name": "cs2menus",
      "detect": "addons/cs2menus",
      "repo": "FemboyKZ/mm-cs2menus",
      "asset": "^cs2menus-.*-linux\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": "addons/cs2menus",
          "to": "addons/cs2menus"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        },
        {
          "from": "cfg/cs2menus",
          "to": "cfg/cs2menus",
          "preserve": true
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_CS2MENUS"
    },
    {
      "name": "multiaddonmanager",
      "detect": "addons/multiaddonmanager",
      "repo": "Source2ZE/MultiAddonManager",
      "asset": "-linux\\.tar\\.gz$",
      "enabled": true,
      "map": [
        {
          "from": "addons/multiaddonmanager",
          "to": "addons/multiaddonmanager"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        },
        {
          "from": "cfg/multiaddonmanager",
          "to": "cfg/multiaddonmanager",
          "preserve": true
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_MULTIADDONMANAGER"
    },
    {
      "name": "serverlistplayersfix_mm",
      "detect": "addons/serverlistplayersfix_mm",
      "repo": "Source2ZE/ServerListPlayersFix",
      "asset": "-linux\\.tar\\.gz$",
      "enabled": true,
      "map": [
        {
          "from": "addons/serverlistplayersfix_mm",
          "to": "addons/serverlistplayersfix_mm"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_SERVERLISTPLAYERSFIX_MM"
    },
    {
      "name": "client_cvar_value",
      "detect": "addons/client_cvar_value",
      "repo": "komashchenko/ClientCvarValue",
      "asset": "^linux\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": "addons/client_cvar_value",
          "to": "addons/client_cvar_value"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_CLIENT_CVAR_VALUE"
    },
    {
      "name": "StripperCS2",
      "detect": "addons/StripperCS2",
      "repo": "Source2ZE/StripperCS2",
      "asset": "^StripperCS2-.*\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": "addons/StripperCS2",
          "to": "addons/StripperCS2"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_STRIPPERCS2"
    },
    {
      "name": "cs2fixes",
      "detect": "addons/cs2fixes",
      "repo": "Source2ZE/CS2Fixes",
      "asset": "-linux\\.tar\\.gz$",
      "enabled": true,
      "map": [
        {
          "from": "addons/cs2fixes",
          "to": "addons/cs2fixes"
        },
        {
          "from": "addons/metamod",
          "to": "addons/metamod"
        },
        {
          "from": "cfg/cs2fixes",
          "to": "cfg/cs2fixes",
          "preserve": true
        },
        {
          "from": "materials/cs2fixes",
          "to": "materials/cs2fixes"
        },
        {
          "from": "particles/cs2fixes",
          "to": "particles/cs2fixes"
        },
        {
          "from": "soundevents",
          "to": "soundevents"
        },
        {
          "from": "sounds",
          "to": "sounds"
        }
      ],
      "framework": "metamod",
      "env": "PLUGIN_CS2FIXES"
    },
    {
      "name": "zResourcePrecacher",
      "detect": "addons/swiftlys2/plugins/zResourcePrecacher",
      "repo": "zhw1nq/zResourcePrecacher_SW2",
      "asset": "^zResourcePrecacher\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": "zResourcePrecacher",
          "to": "addons/swiftlys2/plugins/zResourcePrecacher"
        }
      ],
      "framework": "swiftly",
      "env": "PLUGIN_ZRESOURCEPRECACHER"
    },
    {
      "name": "WeaponSkins",
      "detect": "addons/swiftlys2/plugins/WeaponSkins",
      "repo": "samyycX/WeaponSkins",
      "asset": "^WeaponSkins-v.*\\.zip$",
      "enabled": true,
      "map": [
        {
          "from": "WeaponSkins",
          "to": "addons/swiftlys2/plugins/WeaponSkins"
        }
      ],
      "framework": "swiftly",
      "env": "PLUGIN_WEAPONSKINS"
    }
  ]
}
